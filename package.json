{
  "name": "gm-offline-brickbreaker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build && node scripts/stamp-service-worker-version.mjs",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:colors": "node scripts/test-colors.js",
    "test:colors:dev": "npm run dev & sleep 5 && npm run test:colors && pkill -f 'vite'",
    "test:cloudflare-mobile": "node tests/e2e/cloudflare-mobile-qa.js",
    "test:cloudflare-no-score-reset": "node tests/e2e/cloudflare-no-score-reset-after-brick.js",
    "test:cloudflare-phase-transition": "node tests/e2e/cloudflare-phase-transition-qa.js",
    "test:cloudflare-dashboard-layout": "node tests/e2e/cloudflare-dashboard-layout-qa.js",
    "test:cloudflare-theme": "node tests/e2e/cloudflare-theme-qa.js",
    "test:cloudflare-runtime-update": "node tests/e2e/cloudflare-runtime-update-qa.js"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.2",
    "@capacitor/ios": "^7.4.4",
    "idb": "^7.1.1",
    "prettier": "^3.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^5.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.2.0",
    "puppeteer": "^21.0.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.2.2",
    "vite": "^7.2.4",
    "vitest": "^4.0.13",
    "wrangler": "^4.105.0"
  },
  "engines": {
    "node": ">=23 <24",
    "npm": ">=10 <11"
  }
}
