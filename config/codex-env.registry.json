{
  "version": 1,
  "envFile": ".env",
  "entries": [
    {
      "name": "CLOUDFLARE_ACCOUNT_ID",
      "classification": "secret",
      "required": true,
      "source": "Cloudflare account API",
      "commands": [
        "make cloudflare-deploy",
        "node scripts/cloudflare-pages.js env-check"
      ]
    },
    {
      "name": "CLOUDFLARE_API_TOKEN",
      "classification": "secret",
      "required": true,
      "source": "Cloudflare API token",
      "commands": [
        "make cloudflare-deploy",
        "node scripts/cloudflare-pages.js env-check"
      ]
    },
    {
      "name": "BRIKAYA_CLOUDFLARE_PAGES_PROJECT_NAME",
      "classification": "public-config",
      "required": true,
      "source": "Brikaya Cloudflare Pages project",
      "commands": [
        "make cloudflare-deploy"
      ]
    },
    {
      "name": "BRIKAYA_CLOUDFLARE_PAGES_BRANCH",
      "classification": "public-config",
      "required": true,
      "source": "Brikaya Cloudflare Pages production branch",
      "commands": [
        "make cloudflare-deploy"
      ]
    },
    {
      "name": "BRIKAYA_CLOUDFLARE_PAGES_OUTPUT_DIR",
      "classification": "public-config",
